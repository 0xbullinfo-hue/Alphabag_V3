// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InteractionType {
  LIKE
  COMMENT
  SHARE
}

enum UserRole {
  USER
  FOUNDER
  ADMIN
}

model User {
  id                  String       @id @default(uuid())
  walletAddress       String       @unique
  email              String?      @unique
  communityPoints     Int          @default(0)
  role                UserRole     @default(USER)
  tier                String       @default("FREE")
  project             Project?
  posts               Post[]
  engagements         Engagement[]
  projectName         String?
  projectTicker       String?
  projectManifesto    String?
  projectSocial       String?
  projectWebsite      String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  
  // T2E Integration
  alphaXpBalance      Int          @default(0)
  lifetimeEarned      Int          @default(0)
  syndicateRank       String       @default("NEOPHYTE")
  convertedXpBalance  Int          @default(0)
  t2eBagBalance       Decimal      @default(0)
  preferredWallet     String?
  referralCount       Int          @default(0)
  missionClaims       T2EClaim[]
  tokenClaimRequests  TokenClaimRequest[]
  
  submittedPairs      UserSubmittedPair[]
}

model Project {
  id              String   @id @default(uuid())
  ownerId         String   @unique
  owner           User     @relation(fields: [ownerId], references: [id])
  name            String
  tickerSymbol    String
  contractAddress String   @unique
  theHook         String   // Max 150 chars pitch
  description     String   // Up to 3 paragraphs
  totalSupply     String   // Required for ranking
  websiteUrl      String
  buyLink         String   // Direct DEX or swap router link
  manifestoText   Json?    // Standardized intake form data (kept for backward compat or extra structure)
  isVerified      Boolean  @default(false)
  imageUrls       Json?    // High-resolution image uploaders
  heatIndex       Int      @default(0)
  engagementTotal Int      @default(0)
  totalMentions   Int      @default(0)
  posts           Post[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post {
  id             String       @id @default(uuid())
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  content        String
  likeCount      Int          @default(0)
  commentCount   Int          @default(0)
  shareCount     Int          @default(0)
  boostMultiplier Int          @default(1)
  boostExpiresAt DateTime?
  engagements    Engagement[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Engagement {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  postId          String
  post            Post            @relation(fields: [postId], references: [id])
  interactionType InteractionType
  pointsAwarded   Int             @default(0)
  createdAt       DateTime        @default(now())
}

model UserSubmittedPair {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  contractAddress String
  chainId         String   @default("bsc")
  createdAt       DateTime @default(now())
}

model T2EConfig {
  id                  String   @id @default("global_config")
  isPaused            Boolean  @default(false)
  minimumClaimBalance Int      @default(500)
  updatedAt           DateTime @updatedAt
}

model T2EMission {
  id              String   @id @default(uuid())
  title           String
  description     String
  rewardTokens    Decimal
  type            String   // 'SOCIAL', 'TECHNICAL', 'GROWTH', 'REVIEW'
  frequency       String   @default("ONCE") // 'ONCE', 'DAILY', 'WEEKLY', 'UNLIMITED'
  requiresLink    Boolean  @default(false)
  requiredCount   Int      @default(0)  // For milestone tasks (e.g. refer 3 friends = 3)
  actionUrl       String?
  status          String   @default("ACTIVE") // 'ACTIVE', 'INACTIVE'
  claims          T2EClaim[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model T2EClaim {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  missionId       String
  mission         T2EMission @relation(fields: [missionId], references: [id])
  proofLink       String?
  rewardTokens    Decimal
  createdAt       DateTime   @default(now())
}

model TokenClaimRequest {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  amountXP        Int
  expectedTokens  Int
  walletAddress   String
  status          String     @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  txHash          String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model T2EActivity {
  id              String   @id @default(uuid())
  userHandle      String
  taskType        String
  pointsEarned    Int
  createdAt       DateTime @default(now())
}
